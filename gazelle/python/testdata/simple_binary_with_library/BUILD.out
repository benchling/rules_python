load("@rules_python//python:defs.bzl", "py_binary", "py_library")

py_library(
    name = "simple_binary_with_library",
    srcs = [
        "__init__.py",
        "bar.py",
        "foo.py",
    ],
    visibility = ["//:__subpackages__"],
)

# Gazelle should preserve this custom target and keep bar.py in both libraries.
py_library(
    name = "custom",
    srcs = [
        "bar.py",
    ],
    visibility = ["//:__subpackages__"],
)

py_binary(
    name = "simple_binary_with_library_bin",
    srcs = ["__main__.py"],
    main = "__main__.py",
    visibility = ["//:__subpackages__"],
    deps = [":simple_binary_with_library"],
)
