load("@rules_python//python:defs.bzl", "py_library")

py_library(
    name = "simple_binary_with_library",
    srcs = [
        "__init__.py",
        "bar.py",
        "foo.py",
    ],
)

# Gazelle should preserve this custom target and keep bar.py in both libraries.
py_library(
    name = "custom",
    srcs = [
        "bar.py",
    ],
)
